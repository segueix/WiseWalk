<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <WebView
        android:id="@+id/webView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/mapControlsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_zoom_in"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@android:drawable/btn_default"
            android:contentDescription="Zoom in"
            android:padding="12dp"
            android:src="@android:drawable/btn_plus" />

        <ImageButton
            android:id="@+id/btn_zoom_out"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@android:drawable/btn_default"
            android:contentDescription="Zoom out"
            android:padding="12dp"
            android:src="@android:drawable/btn_minus" />

        <ImageButton
            android:id="@+id/btn_center_me"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@android:drawable/btn_default"
            android:contentDescription="Center map on my location"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_mylocation" />

        <ImageButton
            android:id="@+id/btn_show_route"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:drawable/btn_default"
            android:contentDescription="Show full route"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_directions" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
